{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://setonix-iq/schemas/run.json",
  "title": "Setonix-IQ Run",
  "type": "object",
  "required": ["run_id", "timing", "env", "summary"],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "slurm_id": { "type": ["string", "null"] },
    "label": { "type": "string" },
    "description": { "type": "string" },
    "run_type": {
      "type": "string",
      "enum": ["pipeline", "cpu_baseline", "gpu_baseline", "profile", "deep_profile", "other"]
    },
    "timing": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "time_s"],
        "properties": {
          "command": { "type": "string" },
          "time_s": { "type": "number", "minimum": 0 },
          "memory_kb": { "type": "number", "minimum": 0 }
        }
      }
    },
    "verify": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["status", "file"],
        "properties": {
          "status": { "enum": ["pass", "fail"] },
          "file": { "type": "string" },
          "expected": { "type": "number" },
          "reported": { "type": "number" },
          "diff": { "type": "number", "minimum": 0 }
        }
      }
    },
    "env": {
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "hostname": { "type": "string" },
        "cpu": { "type": "string" },
        "cores": { "type": ["string", "number"] },
        "gcc": { "type": "string" },
        "rocm": { "type": "string" },
        "kernel": { "type": "string" },
        "os": { "type": "string" },
        "glibc": { "type": "string" },
        "python": { "type": "string" },
        "iqtree_version": { "type": "string" },
        "iqtree_binary": { "type": "string" },
        "cpu_sockets": { "type": ["integer", "string"] },
        "cpu_cores_per_socket": { "type": ["integer", "string"] },
        "cpu_threads_per_core": { "type": ["integer", "string"] },
        "cpu_count_logical": { "type": ["integer", "string"] },
        "cpu_governor": { "type": "string" },
        "smt_active": { "type": ["boolean", "string"] },
        "numa_nodes": { "type": ["integer", "string"] },
        "mem_total_kb": { "type": ["integer", "string"] },
        "slurm": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "job_id": { "type": ["string", "integer"] },
            "job_name": { "type": "string" },
            "partition": { "type": "string" },
            "account": { "type": "string" },
            "nodelist": { "type": "string" },
            "num_nodes": { "type": ["integer", "string"] },
            "cpus_per_task": { "type": ["integer", "string"] },
            "ntasks": { "type": ["integer", "string"] },
            "mem_per_node": { "type": ["string", "integer"] },
            "submit_host": { "type": "string" },
            "submit_dir": { "type": "string" }
          }
        }
      }
    },
    "gpu_info": { "type": "string" },
    "dataset_info": {
      "type": "object",
      "properties": {
        "file":             { "type": "string" },
        "file_size_bytes":  { "type": "number", "minimum": 0 },
        "fasta_taxa":       { "type": "integer", "minimum": 0 },
        "fasta_sites":      { "type": "integer", "minimum": 0 },
        "taxa":             { "type": "integer", "minimum": 0 },
        "sites":            { "type": "integer", "minimum": 0 },
        "patterns":         { "type": "integer", "minimum": 0 },
        "constant_sites":   { "type": "integer", "minimum": 0 },
        "invariant_sites":  { "type": "integer", "minimum": 0 },
        "informative_sites":{ "type": "integer", "minimum": 0 },
        "sequence_type":    { "type": "string" }
      }
    },
    "modelfinder": {
      "type": "object",
      "properties": {
        "model_selected":              { "type": "string" },
        "best_model_bic":              { "type": "string" },
        "wall_time_s":                 { "type": "number", "minimum": 0 },
        "log_likelihood":              { "type": "number" },
        "unconstrained_log_likelihood":{ "type": "number" },
        "gamma_alpha":                 { "type": "number" },
        "tree_length":                 { "type": "number" },
        "bic":                         { "type": "number" },
        "aic":                         { "type": "number" },
        "aicc":                        { "type": "number" },
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["model"],
            "properties": {
              "model":          { "type": "string" },
              "log_likelihood": { "type": "number" },
              "aic":            { "type": "number" },
              "aic_weight":     { "type": "number" },
              "aicc":           { "type": "number" },
              "aicc_weight":    { "type": "number" },
              "bic":            { "type": "number" },
              "bic_weight":     { "type": "number" }
            }
          }
        }
      }
    },
    "profile": {
      "type": "object",
      "properties": {
        "dataset": { "type": "string" },
        "threads": { "type": ["integer", "string"] },
        "perf_cmd": { "type": "string" },
        "metrics": {
          "type": "object",
          "properties": {
            "IPC": { "type": "number", "minimum": 0, "maximum": 10 },
            "cache-miss-rate": { "type": "number", "minimum": 0, "maximum": 100 },
            "branch-miss-rate": { "type": "number", "minimum": 0, "maximum": 100 },
            "L1-dcache-miss-rate": { "type": "number", "minimum": 0, "maximum": 100 },
            "frontend-stall-rate": { "type": "number", "minimum": 0, "maximum": 100 },
            "backend-stall-rate": { "type": "number", "minimum": 0, "maximum": 100 },
            "dTLB-miss-rate": { "type": "number", "minimum": 0, "maximum": 100 },
            "iTLB-miss-rate": { "type": "number", "minimum": 0, "maximum": 100 },
            "amd-branch-mispred-rate": { "type": "number", "minimum": 0, "maximum": 100 },
            "amd-l1-dtlb-miss-rate": { "type": "number", "minimum": 0, "maximum": 100 },
            "amd-l2-tlb-miss-rate": { "type": "number", "minimum": 0, "maximum": 100 }
          },
          "additionalProperties": true
        },
        "memory_timeseries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "t_s":     { "type": "number", "minimum": 0 },
              "rss_kb":  { "type": "number", "minimum": 0 },
              "peak_kb": { "type": "number", "minimum": 0 },
              "vms_kb":  { "type": "number", "minimum": 0 },
              "threads_now": { "type": "number", "minimum": 0 },
              "voluntary_cs":   { "type": "number", "minimum": 0 },
              "involuntary_cs": { "type": "number", "minimum": 0 }
            }
          }
        },
        "peak_rss_kb": { "type": "number", "minimum": 0 },
        "numa": {
          "type": "object",
          "properties": {
            "per_node_mb": { "type": "object", "additionalProperties": { "type": "number" } },
            "total_mb":    { "type": "number", "minimum": 0 }
          }
        },
        "io": {
          "type": "object",
          "properties": {
            "read_bytes":  { "type": "number", "minimum": 0 },
            "write_bytes": { "type": "number", "minimum": 0 },
            "syscr":       { "type": "number", "minimum": 0 },
            "syscw":       { "type": "number", "minimum": 0 },
            "rchar":       { "type": "number", "minimum": 0 },
            "wchar":       { "type": "number", "minimum": 0 }
          }
        },
        "per_thread": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tid":   { "type": "integer" },
              "utime": { "type": "number", "minimum": 0 },
              "stime": { "type": "number", "minimum": 0 },
              "nice":  { "type": "number" }
            }
          }
        },
        "raw_events": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "hotspots": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["percent", "function"],
            "properties": {
              "percent": { "type": "number", "minimum": 0, "maximum": 100 },
              "samples": { "type": "number", "minimum": 0 },
              "function": { "type": "string" },
              "module": { "type": "string" },
              "command": { "type": "string" }
            }
          }
        },
        "folded_stacks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["stack", "count"],
            "properties": {
              "stack": { "type": "string" },
              "count": { "type": "number", "minimum": 0 }
            }
          }
        },
        "callstacks": { "type": "object" }
      }
    },
    "summary": {
      "type": "object",
      "required": ["pass", "fail", "total_time", "all_pass"],
      "properties": {
        "pass": { "type": "integer", "minimum": 0 },
        "fail": { "type": "integer", "minimum": 0 },
        "total_time": { "type": "number", "minimum": 0 },
        "all_pass": { "type": "boolean" }
      }
    }
  }
}
