{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://setonix-iq/schemas/profile.json",
  "title": "Setonix-IQ Deep Profile",
  "type": "object",
  "required": ["profile_id"],
  "properties": {
    "profile_id": { "type": "string", "minLength": 1 },
    "slurm_id": { "type": ["string", "null"] },
    "date": { "type": "string" },
    "dataset": { "type": "string" },
    "threads": { "type": ["integer", "string"] },
    "model": { "type": "string" },
    "cpu": {
      "type": "object",
      "properties": {
        "counters": { "type": "object" },
        "derived": {
          "type": "object",
          "properties": {
            "IPC": { "type": "number", "minimum": 0 },
            "cache-miss-rate": { "type": "number", "minimum": 0, "maximum": 100 },
            "frontend-stall-rate": { "type": "number", "minimum": 0, "maximum": 100 }
          }
        },
        "hotspots": { "type": "array" },
        "folded_stacks": { "type": "array" }
      }
    },
    "gpu": { "type": "object" },
    "system": { "type": "object" }
  }
}
