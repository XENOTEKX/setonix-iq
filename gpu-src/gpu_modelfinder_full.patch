+    double df=0,kdf=0, ddf=0,kddf=0, lnL=0,kl=0;
+    for (int p2=0;p2<nptn;p2++){ double f=ptn_freq[p2];
+        { double term=f*pdf[p2],  y=term-kdf,  s=df +y; kdf =(s-df )-y; df =s; }
