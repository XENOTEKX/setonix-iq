+	for (int i = 0; i < nd; i++) v[i+1] = in[i];
+	getVariables(v);                       // v -> model rates (+freqs if FREQ_ESTIMATE) via param_spec
+	decomposeRateMatrix();                 // re-eigendecompose from the new rates
+	delete [] v;
+}
